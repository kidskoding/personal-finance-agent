<% content_for :title, "Subscriptions" %>

<div class="space-y-7">

  <!-- Page header -->
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Subscriptions</h1>
      <div class="flex items-center gap-2 mt-1">
        <% at_earliest = @earliest_month && @date <= @earliest_month %>
        <% if at_earliest %>
          <span class="p-1 text-gray-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          </span>
        <% else %>
          <%= link_to subscriptions_path(month: (@date - 1.month).strftime("%Y-%m")),
              class: "p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" />
            </svg>
          <% end %>
        <% end %>
        <span class="text-sm font-medium text-gray-700 w-28 text-center"><%= @date.strftime("%B %Y") %></span>
        <% if @date < Date.current.beginning_of_month %>
          <%= link_to subscriptions_path(month: (@date + 1.month).strftime("%Y-%m")),
              class: "p-1 rounded hover:bg-gray-100 text-gray-400 hover:text-gray-600 transition-colors" do %>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          <% end %>
        <% else %>
          <span class="p-1 text-gray-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" />
            </svg>
          </span>
        <% end %>
      </div>
    </div>
    <%= button_to analyze_subscriptions_path, method: :post,
        class: "inline-flex items-center gap-2 text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg transition-colors" do %>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
      </svg>
      Run Analysis
    <% end %>
  </div>

  <!-- Monthly Total Card -->
  <% if @recurring_charges.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Monthly Total</p>
          <div class="w-8 h-8 rounded-lg bg-rose-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-rose-500" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-gray-900">$<%= number_with_delimiter(@monthly_total) %></p>
        <p class="text-xs text-gray-400 mt-1">~$<%= number_with_delimiter((@monthly_total * 12).round(2)) %> per year</p>
      </div>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
        <div class="flex items-center justify-between mb-3">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Active Subscriptions</p>
          <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center">
            <svg class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" />
            </svg>
          </div>
        </div>
        <p class="text-3xl font-bold text-gray-900"><%= @recurring_charges.count %></p>
        <p class="text-xs text-gray-400 mt-1">detected from transactions</p>
      </div>
    </div>
  <% end %>

  <!-- Charges Table -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <% if @recurring_charges.empty? %>
      <div class="p-12 text-center">
        <div class="w-14 h-14 rounded-2xl bg-gray-50 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
        </div>
        <p class="text-sm font-semibold text-gray-700">No recurring charges detected</p>
        <p class="text-xs text-gray-400 mt-1 mb-6 max-w-xs mx-auto">Run analysis to automatically detect subscriptions and recurring charges from your transactions.</p>
        <%= button_to analyze_subscriptions_path, method: :post,
            class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
          Run Analysis
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-4 border-b border-gray-100">
        <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">All Charges</h2>
      </div>
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 border-b border-gray-100">
            <th class="text-left px-6 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Merchant</th>
            <th class="text-right px-6 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Amount</th>
            <th class="text-center px-6 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Cadence</th>
            <th class="text-right px-6 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Monthly</th>
            <th class="text-right px-6 py-3 font-semibold text-gray-500 text-xs uppercase tracking-wider">Last Charged</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50">
          <% @recurring_charges.each_with_index do |charge, i| %>
            <% monthly_equiv = case charge.cadence
                               when "weekly" then (charge.amount * 4).round(2)
                               when "annual" then (charge.amount / 12.0).round(2)
                               else charge.amount.round(2)
                               end %>
            <tr class="<%= i.even? ? 'bg-white' : 'bg-gray-50/50' %> hover:bg-indigo-50/30 transition-colors">
              <td class="px-6 py-4">
                <div class="flex items-center gap-3">
                  <div class="flex-shrink-0 w-8 h-8 rounded-lg bg-gray-100 flex items-center justify-center">
                    <span class="text-xs font-bold text-gray-500"><%= charge.merchant_name[0].upcase %></span>
                  </div>
                  <span class="font-semibold text-gray-900"><%= charge.merchant_name %></span>
                </div>
              </td>
              <td class="px-6 py-4 text-right font-medium text-gray-700">$<%= number_with_delimiter(charge.amount) %></td>
              <td class="px-6 py-4 text-center">
                <span class="inline-block px-2.5 py-1 rounded-full text-xs font-semibold
                  <%= charge.cadence == 'monthly' ? 'bg-blue-50 text-blue-700' :
                      charge.cadence == 'annual'  ? 'bg-purple-50 text-purple-700' :
                      charge.cadence == 'weekly'  ? 'bg-orange-50 text-orange-700' :
                                                    'bg-gray-100 text-gray-600' %>">
                  <%= charge.cadence.capitalize %>
                </span>
              </td>
              <td class="px-6 py-4 text-right font-semibold text-gray-900">$<%= number_with_delimiter(monthly_equiv) %></td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-1.5 text-gray-400 text-xs">
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                  </svg>
                  <%= charge.last_charged_on.strftime("%b %-d, %Y") %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr class="bg-gray-50 border-t border-gray-200">
            <td colspan="3" class="px-6 py-4 text-sm font-semibold text-gray-700">Total</td>
            <td class="px-6 py-4 text-right text-sm font-bold text-gray-900">$<%= number_with_delimiter(@monthly_total) %></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    <% end %>
  </div>

</div>
