<% content_for :title, "Settings" %>

<div class="space-y-7 max-w-2xl">

  <!-- Page header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Settings</h1>
    <p class="text-sm text-gray-500 mt-0.5">Manage your connected accounts and data</p>
  </div>

  <!-- Connected Banks -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-5">Connected Banks</h2>
    <% if @plaid_items.empty? %>
      <p class="text-sm text-gray-400">No bank accounts connected.</p>
    <% else %>
      <div class="space-y-3">
        <% @plaid_items.each do |item| %>
          <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 border border-gray-100">
            <div>
              <p class="text-sm font-semibold text-gray-900">
                <%= item.institution_name.presence || "Bank Account" %>
              </p>
              <p class="text-xs text-gray-500 mt-0.5">
                <%= pluralize(item.accounts.size, "account") %> &middot; Connected <%= item.created_at.strftime("%b %-d, %Y") %>
              </p>
            </div>
            <%= button_to disconnect_bank_path(item), method: :delete,
                data: { turbo_confirm: "Disconnect this bank? This will remove all associated accounts and transactions." },
                class: "text-xs font-medium text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition-colors" do %>
              Disconnect
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <div class="mt-5 pt-5 border-t border-gray-100">
      <button
        data-controller="plaid-link"
        data-plaid-link-link-token-url-value="<%= link_token_path %>"
        data-plaid-link-exchange-url-value="<%= exchange_public_token_path %>"
        data-label="Connect a bank account"
        data-action="click->plaid-link#open"
        class="inline-flex items-center gap-2 text-sm font-semibold text-white bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg transition-colors disabled:opacity-50"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        Connect a bank account
      </button>
    </div>
  </div>

  <!-- Data Management -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Data Management</h2>
    <p class="text-xs text-gray-400 mb-5">These actions are irreversible.</p>

    <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 border border-gray-100">
      <div>
        <p class="text-sm font-semibold text-gray-900">Clear AI Recommendations</p>
        <p class="text-xs text-gray-500 mt-0.5">
          <%= pluralize(current_user.recommendations.count, "recommendation") %> stored &middot; You can regenerate them at any time
        </p>
      </div>
      <%= button_to clear_recommendations_path, method: :delete,
          data: { turbo_confirm: "Clear all recommendations? You can regenerate them at any time." },
          class: "text-xs font-medium text-red-600 hover:text-red-800 bg-red-50 hover:bg-red-100 px-3 py-1.5 rounded-lg transition-colors" do %>
        Clear all
      <% end %>
    </div>
  </div>

</div>
