<% content_for :title, "Action Plan" %>

<div class="space-y-7">

  <!-- Page header -->
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Action Plan</h1>
      <p class="text-sm text-gray-500 mt-0.5"><%= @date.strftime("%B %Y") %></p>
    </div>
    <div class="flex items-center gap-4">
      <% if @total_savings > 0 %>
        <div class="text-right">
          <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Potential Savings</p>
          <p class="text-2xl font-bold text-emerald-600">$<%= number_with_delimiter(@total_savings.round(2)) %><span class="text-sm font-medium text-emerald-500">/mo</span></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Savings Opportunities -->
  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
    <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-5">Savings Opportunities</h2>
    <% if @opportunities.empty? %>
      <div class="py-10 text-center">
        <div class="w-12 h-12 rounded-full bg-gray-100 flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75" />
          </svg>
        </div>
        <p class="text-sm text-gray-400">No spending data available yet.</p>
        <p class="text-xs text-gray-300 mt-1">Connect a bank account and sync transactions to see opportunities.</p>
      </div>
    <% else %>
      <div class="space-y-3">
        <% @opportunities.each_with_index do |opp, i| %>
          <div class="flex items-center justify-between p-4 rounded-xl bg-gray-50 border border-gray-100 hover:border-gray-200 transition-colors">
            <div class="flex items-center gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-emerald-100 text-emerald-700 text-xs font-bold flex items-center justify-center"><%= i + 1 %></span>
              <div>
                <p class="text-sm font-semibold text-gray-900"><%= opp[:category].gsub("_", " ").titleize %></p>
                <p class="text-xs text-gray-500 mt-0.5">
                  Currently $<%= number_with_delimiter(opp[:current_spend]) %>/mo &middot; Reduce by <%= opp[:reduction_percentage] %>%
                </p>
              </div>
            </div>
            <div class="flex-shrink-0 ml-4">
              <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-sm font-semibold">
                Save $<%= number_with_delimiter(opp[:estimated_savings]) %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- AI Recommendations -->
  <div class="space-y-4">
    <div class="flex items-center justify-between">
      <h2 class="text-xs font-semibold text-gray-500 uppercase tracking-wider">AI Recommendations</h2>
      <% unless @recommendation_this_month %>
        <% if @has_accounts %>
          <%= button_to generate_action_plan_path, method: :post,
              class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition-colors" do %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
            </svg>
            Generate for <%= @date.strftime("%B") %>
          <% end %>
        <% end %>
      <% end %>
    </div>

    <% if @recommendations.any? %>
      <% @recommendations.each do |rec| %>
        <div class="relative overflow-hidden bg-gradient-to-br from-indigo-50 to-white rounded-2xl border border-indigo-100 shadow-sm p-6">
          <div class="absolute right-0 top-0 w-32 h-32 rounded-full bg-indigo-100/30 -mr-8 -mt-8"></div>
          <div class="relative">
            <div class="flex items-center justify-between mb-4">
              <div class="flex items-center gap-2">
                <div class="w-6 h-6 rounded-md bg-indigo-600 flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
                  </svg>
                </div>
                <span class="text-xs font-semibold text-indigo-700 bg-indigo-100 px-2 py-0.5 rounded-full">
                  <%= rec.month.strftime("%B %Y") %>
                </span>
              </div>
              <span class="text-xs text-gray-400"><%= rec.generated_at.strftime("%b %-d, %Y at %-I:%M %p") %></span>
            </div>
            <div class="text-sm text-gray-700 markdown">
              <%= render_markdown(rec.content) %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-12 text-center">
        <div class="w-14 h-14 rounded-2xl bg-indigo-50 flex items-center justify-center mx-auto mb-4">
          <svg class="w-7 h-7 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z" />
          </svg>
        </div>
        <p class="text-base font-semibold text-gray-800">No recommendations yet</p>
        <% unless @has_accounts %>
          <p class="text-sm text-gray-400 mt-1 mb-6 max-w-sm mx-auto">Connect a bank account first to generate personalized recommendations.</p>
          <%= link_to settings_path, class: "inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors" do %>
            Connect a bank account
          <% end %>
        <% else %>
          <p class="text-sm text-gray-400 mt-1 max-w-sm mx-auto">Use the "Generate for <%= @date.strftime("%B") %>" button above to get personalized AI advice.</p>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
