<% content_for :title, "Create account" %>

<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
  <div class="w-full max-w-md">

    <!-- Brand -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-indigo-600 mb-4">
        <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75" />
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900">Create your account</h1>
      <p class="text-sm text-gray-500 mt-1">Start understanding your finances</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-8">
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="space-y-5">

          <div class="grid grid-cols-2 gap-4">
            <div>
              <%= f.label :first_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.text_field :first_name, autofocus: true, autocomplete: "given-name",
                  class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            </div>
            <div>
              <%= f.label :last_name, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
              <%= f.text_field :last_name, autocomplete: "family-name",
                  class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            </div>
          </div>

          <div>
            <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.email_field :email, autocomplete: "email",
                class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
          </div>

          <div>
            <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
            <p class="text-xs text-gray-400 mt-1"><%= @minimum_password_length %> characters minimum</p>
          </div>

          <div>
            <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
            <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition" %>
          </div>

          <%= f.submit "Create account", class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-lg px-4 py-2.5 text-sm transition cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <p class="text-center text-sm text-gray-500 mt-6">
      Already have an account?
      <%= link_to "Sign in", new_session_path(resource_name), class: "font-medium text-indigo-600 hover:text-indigo-800" %>
    </p>

  </div>
</div>
