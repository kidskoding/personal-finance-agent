<% content_for :title, "Dashboard" %>

<div class="space-y-6">
  <!-- Header -->
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @date.strftime("%B %Y") %></p>
  </div>

  <!-- Total Spend Card -->
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <p class="text-sm text-gray-500 font-medium uppercase tracking-wide">Total Spend This Month</p>
    <p class="text-4xl font-bold text-gray-900 mt-2">$<%= number_with_delimiter(@total_spend.round(2)) %></p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Category Breakdown -->
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Spending by Category</h2>
      <% if @categories.empty? %>
        <p class="text-sm text-gray-400">No transactions this month.</p>
      <% else %>
        <ul class="space-y-3">
          <% @categories.each do |cat| %>
            <li>
              <div class="flex justify-between text-sm mb-1">
                <span class="text-gray-700"><%= cat[:category].gsub("_", " ").titleize %></span>
                <span class="font-medium text-gray-900">$<%= number_with_delimiter(cat[:total]) %> <span class="text-gray-400 font-normal">(<%= cat[:percentage] %>%)</span></span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-1.5">
                <div class="bg-indigo-500 h-1.5 rounded-full" style="width: <%= cat[:percentage] %>%"></div>
              </div>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <!-- Top Merchants -->
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <h2 class="text-base font-semibold text-gray-900 mb-4">Top Merchants</h2>
      <% if @merchants.empty? %>
        <p class="text-sm text-gray-400">No transactions this month.</p>
      <% else %>
        <ol class="space-y-3">
          <% @merchants.each do |m| %>
            <li class="flex items-center justify-between">
              <div class="flex items-center gap-3">
                <span class="text-xs font-semibold text-gray-400 w-4">#<%= m[:rank] %></span>
                <span class="text-sm text-gray-700"><%= m[:merchant] %></span>
              </div>
              <span class="text-sm font-medium text-gray-900">$<%= number_with_delimiter(m[:total]) %></span>
            </li>
          <% end %>
        </ol>
      <% end %>
    </div>
  </div>

  <!-- Spending Spike Alert -->
  <% if @spikes.any? %>
    <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
      <h2 class="text-base font-semibold text-amber-800 mb-1">Spending Alert</h2>
      <% spike = @spikes.first %>
      <p class="text-sm text-amber-700">
        Your <strong><%= spike[:category].gsub("_", " ").titleize %></strong> spending is
        <strong><%= spike[:spike_percentage] %>% above</strong> your 3-month average
        ($<%= number_with_delimiter(spike[:current_total]) %> vs. $<%= number_with_delimiter(spike[:baseline_average]) %> avg).
      </p>
    </div>
  <% end %>

  <!-- Latest Recommendation -->
  <% if @recommendation %>
    <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-6">
      <div class="flex items-start justify-between mb-2">
        <h2 class="text-base font-semibold text-indigo-900">Latest Recommendation</h2>
        <span class="text-xs text-indigo-400"><%= @recommendation.generated_at.strftime("%b %-d, %Y") %></span>
      </div>
      <div class="text-sm text-indigo-800 prose prose-sm max-w-none">
        <%= simple_format(@recommendation.content.truncate(600)) %>
      </div>
      <%= link_to "View full action plan →", action_plan_path, class: "inline-block mt-3 text-sm font-medium text-indigo-600 hover:text-indigo-800" %>
    </div>
  <% end %>
</div>
